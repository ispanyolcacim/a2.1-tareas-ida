<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>A2.1 – H1 1-2. Ders – Pretérito Perfecto</title>
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --pink1:  #F6C4C3;
  --pink2:  #F8DBD8;
  --pink3:  #FAAED2;
  --yellow: #F8CE5B;
  --cream:  #FFFFE0;
  --yellow2:#FAFC97;
  --dark:   #5a3a3a;
  --mid:    #8a6060;
  --light:  #fff9f9;
  --white:  #ffffff;
  --green:  #6aab7a;
  --red:    #d97070;
  --radius: 14px;
}

body {
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  background: linear-gradient(160deg, #fff5f5 0%, #fffde8 60%, #fff0f8 100%);
  min-height: 100vh;
  color: var(--dark);
}

/* ── HEADER ── */
.header {
  background: linear-gradient(135deg, var(--pink1), var(--pink3));
  padding: 18px 20px 14px;
  text-align: center;
  box-shadow: 0 4px 18px rgba(246,196,195,0.45);
  position: relative; overflow: hidden;
}
.header::before {
  content:''; position:absolute; inset:0;
  background: repeating-linear-gradient(45deg,transparent,transparent 14px,rgba(255,255,255,0.13) 14px,rgba(255,255,255,0.13) 15px);
}
.header-tag {
  display:inline-block;
  background:rgba(255,255,255,0.4);
  border:1.5px solid rgba(255,255,255,0.6);
  border-radius:20px; font-size:11px; font-weight:700;
  letter-spacing:2px; text-transform:uppercase;
  padding:3px 14px; margin-bottom:8px;
  color:var(--dark); position:relative;
}
.header h1 {
  font-size: clamp(16px,4vw,23px); font-weight:800;
  color:var(--dark); position:relative;
  text-shadow:0 1px 4px rgba(255,255,255,0.5);
}
.header-sub { font-size:12px; color:var(--mid); margin-top:4px; position:relative; }

/* ── SCREENS ── */
.screen { display:none; animation:fadeIn 0.3s ease; }
.screen.active { display:block; }
@keyframes fadeIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }

/* ══ SCREEN 1: AD SEÇİMİ ══ */
.name-body { max-width:420px; margin:0 auto; padding:32px 20px; text-align:center; }
.name-body h2 { font-size:20px; color:var(--dark); margin-bottom:5px; }
.name-body p  { font-size:13px; color:var(--mid); margin-bottom:20px; }

.name-select {
  width:100%; padding:13px 16px; font-size:15px;
  background:var(--white); border:2px solid var(--pink1);
  border-radius:var(--radius); color:var(--dark);
  appearance:none; cursor:pointer; margin-bottom:14px;
  font-family:inherit; transition:border-color 0.2s, box-shadow 0.2s;
}
.name-select:focus { outline:none; border-color:var(--yellow); box-shadow:0 0 0 3px rgba(248,206,91,0.2); }

.info-box {
  background:var(--white); border:1.5px solid var(--pink2);
  border-radius:var(--radius); padding:14px 16px;
  margin-bottom:18px; text-align:left; font-size:13px; line-height:1.75;
  box-shadow:0 2px 10px rgba(246,196,195,0.18);
}
.ib-row { display:flex; align-items:flex-start; gap:9px; margin-bottom:5px; }
.ib-row:last-child { margin-bottom:0; }
.ib-dot { width:8px; height:8px; border-radius:50%; background:var(--yellow); flex-shrink:0; margin-top:5px; }
.ib-hr  { height:1px; background:var(--pink2); margin:9px 0; }

/* ── BUTTONS ── */
.btn {
  display:inline-flex; align-items:center; justify-content:center; gap:7px;
  padding:12px 24px; border:none; border-radius:var(--radius);
  font-size:14px; font-weight:700; cursor:pointer;
  transition:all 0.2s; font-family:inherit;
}
.btn-pink   { background:linear-gradient(135deg,var(--pink1),var(--pink3)); color:var(--dark); box-shadow:0 4px 12px rgba(246,196,195,0.45); }
.btn-pink:hover   { transform:translateY(-2px); box-shadow:0 6px 18px rgba(246,196,195,0.65); }
.btn-yellow { background:linear-gradient(135deg,var(--yellow),#e8b84b); color:var(--dark); box-shadow:0 4px 12px rgba(248,206,91,0.4); }
.btn-yellow:hover { transform:translateY(-2px); box-shadow:0 6px 18px rgba(248,206,91,0.55); }
.btn-outline { background:var(--white); border:2px solid var(--pink1); color:var(--dark); }
.btn-outline:hover { background:var(--pink2); }
.btn-sm   { padding:9px 18px; font-size:13px; }
.btn-full { width:100%; }
.btn:disabled { opacity:0.35; cursor:not-allowed; transform:none !important; }

/* ══ SCREEN 2: QUIZ ══ */
.quiz-wrap { max-width:620px; margin:0 auto; padding:16px; }

/* Üst bar */
.top-bar {
  display:flex; align-items:center; justify-content:space-between;
  background:var(--white); border:1.5px solid var(--pink2);
  border-radius:var(--radius); padding:10px 16px;
  margin-bottom:12px; gap:8px; flex-wrap:wrap;
  box-shadow:0 2px 8px rgba(246,196,195,0.18);
}
.top-student { font-size:12px; color:var(--mid); font-weight:600; }
.top-scores  { display:flex; gap:14px; }
.top-score-item { display:flex; align-items:center; gap:5px; font-size:13px; font-weight:700; }
.sc-correct { color:var(--green); }
.sc-wrong   { color:var(--red); }

/* Progress */
.prog-wrap { margin-bottom:14px; }
.prog-bar  { height:7px; background:var(--pink2); border-radius:4px; overflow:hidden; }
.prog-fill { height:100%; background:linear-gradient(90deg,var(--pink1),var(--yellow)); border-radius:4px; transition:width 0.4s ease; width:0%; }
.prog-info { display:flex; justify-content:space-between; font-size:11px; color:var(--mid); margin-top:3px; }

/* Section badge */
.section-badge {
  display:inline-flex; align-items:center; gap:8px;
  background:linear-gradient(90deg,var(--pink1),var(--pink3));
  border-radius:20px; padding:5px 14px;
  font-size:11px; font-weight:700; letter-spacing:1px; text-transform:uppercase;
  color:var(--dark); margin-bottom:10px;
  box-shadow:0 2px 8px rgba(246,196,195,0.3);
}

/* Soru kartı */
.q-card {
  background:var(--white);
  border:1.5px solid var(--pink2);
  border-radius:var(--radius);
  overflow:hidden;
  box-shadow:0 3px 14px rgba(246,196,195,0.2);
  margin-bottom:12px;
}

.q-head {
  padding:16px 18px 14px;
  border-bottom:1px solid var(--pink2);
  display:flex; gap:12px; align-items:flex-start;
}
.q-num {
  background:linear-gradient(135deg,var(--pink1),var(--pink3));
  color:var(--dark); width:30px; height:30px; border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-size:13px; font-weight:800; flex-shrink:0; margin-top:1px;
}
.q-text { font-size:14.5px; line-height:1.65; flex:1; color:var(--dark); font-weight:500; }

.reading-tag {
  display:inline-block;
  background:rgba(248,206,91,0.22); border:1px solid rgba(248,206,91,0.5);
  color:#9a7000; font-size:10px; font-weight:700;
  letter-spacing:1.5px; text-transform:uppercase;
  padding:2px 8px; border-radius:4px; margin-bottom:8px;
}
.reading-box {
  background:#fffde8; border-left:3px solid var(--yellow);
  border-radius:0 8px 8px 0;
  padding:10px 14px; margin:8px 0 10px;
  font-size:13px; line-height:1.75; font-style:italic; color:var(--mid);
}
.q-sub { font-weight:600; font-size:14.5px; margin-top:6px; color:var(--dark); }

/* Şıklar */
.q-opts { padding:12px 16px 14px; display:grid; gap:8px; }
.opt-btn {
  display:flex; align-items:flex-start; gap:10px;
  padding:11px 14px;
  background:#fdf8f8; border:1.5px solid var(--pink2);
  border-radius:10px; color:var(--dark);
  font-size:13.5px; line-height:1.5;
  cursor:pointer; text-align:left; width:100%;
  transition:all 0.18s; font-family:inherit;
}
.opt-btn:hover:not(:disabled) { background:var(--cream); border-color:var(--yellow); transform:translateX(4px); }
.opt-btn:disabled { cursor:default; }
.opt-letter {
  background:var(--pink2); color:var(--dark);
  border-radius:6px; width:24px; height:24px;
  display:flex; align-items:center; justify-content:center;
  font-size:11px; font-weight:800; flex-shrink:0;
  transition:all 0.18s;
}
.opt-btn.correct { background:#edfaf2; border-color:#8dcca0; }
.opt-btn.correct .opt-letter { background:var(--green); color:white; }
.opt-btn.wrong   { background:#fdf0f0; border-color:#e8a0a0; }
.opt-btn.wrong   .opt-letter { background:var(--red);   color:white; }

/* Açıklama */
.explanation {
  display:none;
  margin:0 16px 14px;
  background:#fffde8; border-left:3px solid var(--yellow);
  border-radius:0 8px 8px 0;
  padding:11px 14px; font-size:13px; line-height:1.7; color:var(--mid);
}
.explanation.show { display:block; }
.exp-label { font-size:10px; font-weight:800; letter-spacing:1.5px; text-transform:uppercase; color:#9a7000; margin-bottom:4px; }

/* Navigasyon butonları */
.nav-bar {
  display:flex; align-items:center; justify-content:space-between;
  gap:10px; margin-top:4px; margin-bottom:16px; flex-wrap:wrap;
}
.nav-center { font-size:13px; color:var(--mid); font-weight:600; text-align:center; flex:1; }

/* Teslim et barı */
.finish-bar {
  position:sticky; bottom:0;
  background:rgba(255,249,249,0.97);
  backdrop-filter:blur(10px);
  border-top:1.5px solid var(--pink2);
  padding:11px 16px;
  display:flex; align-items:center; justify-content:space-between; gap:12px; flex-wrap:wrap;
  box-shadow:0 -4px 14px rgba(246,196,195,0.22);
}
.finish-info { font-size:12px; color:var(--mid); }
.finish-info strong { color:var(--dark); font-size:14px; }

/* Yazma bölümü (son karttan sonra) */
.writing-card {
  background:var(--white); border:1.5px solid var(--pink2);
  border-radius:var(--radius); margin-bottom:14px; overflow:hidden;
  box-shadow:0 2px 10px rgba(246,196,195,0.15);
}
.writing-head {
  background:linear-gradient(90deg,var(--pink1),var(--pink3));
  padding:11px 16px; display:flex; align-items:center; gap:10px;
  font-weight:700; font-size:14px; color:var(--dark);
}
.writing-body { padding:16px; font-size:13.5px; line-height:1.8; color:var(--dark); }
.writing-body strong { color:#9a7000; }
.writing-body ul { margin:8px 0 8px 18px; }
.writing-body li { margin-bottom:4px; }
.rubric { width:100%; border-collapse:collapse; margin-top:12px; font-size:13px; }
.rubric th { background:var(--pink2); padding:7px 12px; text-align:left; font-size:11px; letter-spacing:.8px; text-transform:uppercase; color:var(--mid); }
.rubric td { padding:8px 12px; border-bottom:1px solid var(--pink2); vertical-align:top; }
.rubric tr:last-child td { border-bottom:none; font-weight:700; }
.rubric .pts { text-align:right; color:#9a7000; font-weight:700; white-space:nowrap; }

/* ══ SCREEN 3: SONUÇ ══ */
.result-wrap { max-width:440px; margin:0 auto; padding:28px 20px; text-align:center; }
.result-card {
  background:var(--white); border:1.5px solid var(--pink2);
  border-radius:20px; padding:28px 22px; margin-bottom:14px;
  box-shadow:0 6px 24px rgba(246,196,195,0.3);
}
.result-emoji { font-size:50px; margin-bottom:10px; }
.result-name  { font-size:14px; color:var(--mid); margin-bottom:3px; }
.result-title { font-size:16px; font-weight:700; color:var(--dark); margin-bottom:16px; }
.result-score-big { font-size:62px; font-weight:900; line-height:1; color:var(--dark); }
.result-score-big span { font-size:24px; font-weight:400; color:var(--mid); }
.result-pct   { font-size:13px; color:var(--mid); margin-top:4px; margin-bottom:18px; }
.result-stats { display:flex; justify-content:center; gap:12px; flex-wrap:wrap; margin-bottom:18px; }
.rs-item {
  background:linear-gradient(135deg,var(--pink2),var(--cream));
  border:1px solid var(--pink1); border-radius:12px;
  padding:11px 16px; min-width:76px; text-align:center;
}
.rs-item .rs-n { font-size:28px; font-weight:800; line-height:1; }
.rs-item .rs-l { font-size:11px; color:var(--mid); margin-top:3px; }
.rs-correct .rs-n { color:var(--green); }
.rs-wrong   .rs-n { color:var(--red); }
.rs-blank   .rs-n { color:#bbb; }

.status-badge {
  display:inline-flex; align-items:center; gap:7px;
  padding:9px 20px; border-radius:50px;
  font-size:13px; font-weight:700; margin-bottom:14px;
}
.status-pending { background:rgba(248,206,91,0.18); border:1.5px solid rgba(248,206,91,0.45); color:#9a7000; }
.status-ok      { background:rgba(106,171,122,0.15); border:1.5px solid rgba(106,171,122,0.4);  color:#3a7a4a; }
.status-error   { background:rgba(217,112,112,0.15); border:1.5px solid rgba(217,112,112,0.4);  color:#a04040; }
.result-actions { display:flex; gap:10px; justify-content:center; flex-wrap:wrap; margin-top:6px; }

/* ══ MODAL ══ */
.modal-bg {
  display:none; position:fixed; inset:0;
  background:rgba(90,58,58,0.38); backdrop-filter:blur(6px);
  z-index:999; align-items:center; justify-content:center; padding:20px;
}
.modal-bg.open { display:flex; }
.modal-box {
  background:var(--white); border:1.5px solid var(--pink1);
  border-radius:20px; padding:28px 26px 22px;
  max-width:340px; width:100%; text-align:center;
  box-shadow:0 18px 48px rgba(246,196,195,0.5);
  animation:popIn 0.27s cubic-bezier(0.175,0.885,0.32,1.275);
}
@keyframes popIn { from{transform:scale(0.84);opacity:0} to{transform:scale(1);opacity:1} }
.modal-box h3   { font-size:19px; color:var(--dark); margin-bottom:8px; }
.modal-score    { font-size:42px; font-weight:900; color:var(--dark); line-height:1; margin-bottom:6px; }
.modal-score span { font-size:18px; font-weight:400; color:var(--mid); }
.modal-box p    { font-size:13px; color:var(--mid); margin-bottom:18px; line-height:1.6; }
.modal-actions  { display:flex; gap:10px; justify-content:center; }
</style>
</head>
