// ── CONFIG ──
const APPS_SCRIPT_URL = 'YOUR_APPS_SCRIPT_URL_HERE';
const SPREADSHEET_ID  = '1wziyxdRdIGL7OEq4yRib0i_CaCWJGI14fwDyMKB4abw';
const SHEET_NAME      = 'A2.1';
const TASK_COLUMN     = 'H1 – 1-2.Ders';

// ── SORULAR ──
const QUESTIONS = [
  {id:1,sec:1,q:'¿Cuál de las siguientes frases usa correctamente el Pretérito Perfecto con un marcador temporal relacionado con el presente?',opts:['Este año he aprendido muchas estructuras nuevas.','Ayer he aprendido muchas estructuras nuevas.','En 2019 he aprendido muchas estructuras nuevas.','La semana pasada he aprendido muchas estructuras nuevas.'],ans:0,exp:'<b>Este año</b> hâlâ devam eden bir zaman dilimidir → Pretérito Perfecto doğrudur. "Ayer", "en 2019", "la semana pasada" kapalı zaman → Pretérito Indefinido gerekir.'},
  {id:2,sec:1,q:'Elige la opción en la que el participio pasado está correctamente formado.',opts:['He escribido la carta.','He escrito la carta.','He escribado la carta.','He escribto la carta.'],ans:1,exp:'<b>Escribir</b> → düzensiz participio: <b>escrito</b>. "Escribido" yanlış — bu fiil düzensiz participio alır.'},
