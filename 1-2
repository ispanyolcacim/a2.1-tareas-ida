// ── STATE ──
let studentName = '';
let answers = {};       // { qId: chosenIdx }
let currentQ = 0;       // şu an görünen soru index (0-29)
let submitted = false;

// ── SCREENS ──
function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('screen-' + id).classList.add('active');
  window.scrollTo(0,0);
}

// ── START ──
function startQuiz() {
  const sel = document.getElementById('name-select');
  if (!sel.value) { alert('Lütfen adınızı seçin!'); return; }
  studentName = sel.value;
  currentQ = 0;
  answers = {};
  submitted = false;
  document.getElementById('top-student').textContent = studentName;
  showScreen('quiz');
  renderQuestion();
}

// ── RENDER QUESTION ──
function renderQuestion() {
  const q = QUESTIONS[currentQ];
  const letters = ['A','B','C','D'];

  // Section badge
  const secNames = {1:'Kısım 1 — Gramatik MasterClass', 2:'Kısım 2 — Okuduğunu Anlama'};
  document.getElementById('prog-section').textContent = secNames[q.sec];

  // Progress
  const answered = Object.keys(answers).length;
  document.getElementById('prog-fill').style.width = (answered / QUESTIONS.length * 100) + '%';
  document.getElementById('prog-cur').textContent  = currentQ + 1;
  document.getElementById('nav-center').textContent = (currentQ + 1) + ' / 30';
  document.getElementById('bb-answered').textContent = answered;

  // Nav buttons
  document.getElementById('btn-prev').disabled = (currentQ === 0);
  const isLast = (currentQ === QUESTIONS.length - 1);
  const btnNext = document.getElementById('btn-next');
  if (isLast) {
    btnNext.textContent = '✔ Bitir';
    btnNext.className = 'btn btn-yellow btn-sm';
    btnNext.onclick = openFinishModal;
  } else {
    btnNext.textContent = 'İleri →';
    btnNext.className = 'btn btn-pink btn-sm';
    btnNext.onclick = () => navigate(1);
  }

  // Soru HTML
  const readingHTML = q.reading
    ? `<div class="reading-tag">📖 Okuma Metni</div>
       <div class="reading-box">${q.reading}</div>
       <div class="q-sub">${q.q}</div>`
    : '';

  const optsHTML = q.opts.map((o, i) => {
    let cls = 'opt-btn';
    const userAns = answers[q.id];
    if (userAns !== undefined) {
      if (i === q.ans) cls += ' correct';
      if (i === userAns && userAns !== q.ans) cls += ' wrong';
    }
    const disabled = (userAns !== undefined) ? 'disabled' : '';
    return `<button class="${cls}" ${disabled} onclick="answer(${q.id},${i})">
              <span class="opt-letter">${letters[i]}</span>
              <span>${o}</span>
            </button>`;
  }).join('');

  const expShow = answers[q.id] !== undefined ? 'show' : '';

  document.getElementById('q-area').innerHTML = `
    <div class="section-badge">${secNames[q.sec]}</div>
    <div class="q-card">
      <div class="q-head">
        <div class="q-num">${q.id}</div>
        <div class="q-text">
          ${q.reading ? readingHTML : q.q}
        </div>
      </div>
      <div class="q-opts">${optsHTML}</div>
      <div class="explanation ${expShow}" id="exp-box">
        <div class="exp-label">💡 Açıklama</div>
        ${q.exp}
      </div>
    </div>`;
}

// ── NAVIGATE ──
function navigate(dir) {
  currentQ = Math.max(0, Math.min(QUESTIONS.length - 1, currentQ + dir));
  renderQuestion();
}

// ── ANSWER ──
function answer(qId, chosen) {
  if (answers[qId] !== undefined || submitted) return;
  answers[qId] = chosen;
  // Update HUD
  let correct = 0, wrong = 0;
  QUESTIONS.forEach(q => {
    const a = answers[q.id];
    if (a === undefined) return;
    if (a === q.ans) correct++; else wrong++;
  });
  document.getElementById('sc-correct').textContent = correct;
  document.getElementById('sc-wrong').textContent   = wrong;
  // Re-render to show correct/wrong + explanation
  renderQuestion();
}

// ── MODAL ──
function openFinishModal() {
  let correct = 0;
  QUESTIONS.forEach(q => { if (answers[q.id] === q.ans) correct++; });
  document.getElementById('modal-score-preview').innerHTML = (correct*2) + '<span>/60</span>';
  document.getElementById('modal-finish').classList.add('open');
}
function closeModal() { document.getElementById('modal-finish').classList.remove('open'); }

// ── SUBMIT ──
function submitQuiz() {
  closeModal();
  submitted = true;
  let correct = 0, wrong = 0;
  QUESTIONS.forEach(q => {
    const a = answers[q.id];
    if (a === undefined) return;
    if (a === q.ans) correct++; else wrong++;
  });
  const blank = QUESTIONS.length - Object.keys(answers).length;
  const score = correct * 2;

  document.getElementById('res-name').textContent  = studentName;
  document.getElementById('res-score').innerHTML   = score + '<span>/60</span>';
  document.getElementById('res-pct').textContent   = '%' + Math.round(score/60*100) + ' başarı';
  document.getElementById('res-c').textContent     = correct;
  document.getElementById('res-w').textContent     = wrong;
  document.getElementById('res-b').textContent     = blank;

  showScreen('result');
  sendToSheets(studentName, score, correct, wrong, blank);
}

// ── SHEETS ──
async function sendToSheets(name, score, correct, wrong, blank) {
  const el = document.getElementById('res-status');
  if (!APPS_SCRIPT_URL || APPS_SCRIPT_URL === 'YOUR_APPS_SCRIPT_URL_HERE') {
    el.className = 'status-badge status-error';
    el.textContent = '⚠️ Apps Script URL girilmedi';
    return;
  }
  try {
    await fetch(APPS_SCRIPT_URL, {
      method:'POST', mode:'no-cors',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ spreadsheetId:SPREADSHEET_ID, sheetName:SHEET_NAME, studentName:name, taskColumn:TASK_COLUMN, score, correct, wrong, blank, submittedAt:new Date().toLocaleString('tr-TR') })
    });
    el.className = 'status-badge status-ok';
    el.textContent = '✅ Ödev başarıyla kaydedildi!';
  } catch(e) {
    el.className = 'status-badge status-error';
    el.textContent = '⚠️ Kaydedilemedi — Profe\'ye bildirin';
  }
}

// ── REVIEW ──
function reviewAnswers() {
  showScreen('quiz');
  const firstWrong = QUESTIONS.findIndex(q => answers[q.id] !== undefined && answers[q.id] !== q.ans);
  currentQ = firstWrong >= 0 ? firstWrong : 0;
  renderQuestion();
}

function goToName() {
  answers = {}; submitted = false; currentQ = 0;
  document.getElementById('name-select').value = '';
  showScreen('name');
}
</script>
